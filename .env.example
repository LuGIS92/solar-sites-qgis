# Solar Sites Plugin – Configuration Template
# Copy to .env and adjust. Plugin works without .env using built-in defaults.

# ── DLR Solar Atlas (public, no API key) ──────────────────────────────────────
DLR_WMTS_URL=https://geoservice.dlr.de/eoc/gwc/service/wmts
DLR_LAYER=solarde:SDE_BUILDINGS
DLR_ZOOM=19

# ── PVGIS EU JRC (public, no key) ────────────────────────────────────────────
PVGIS_URL=https://re.jrc.ec.europa.eu/api/v5_2
PVGIS_SYSTEM_LOSS=14.0

# ── Solar panel parameters ────────────────────────────────────────────────────
PANEL_EFFICIENCY=0.20
PANEL_POWER_PER_SQM=0.175
ROOF_COVERAGE_FLAT=0.65
ROOF_COVERAGE_PITCHED=0.55
MIN_ROOF_AREA_SQM=100.0

# ── Database (PostGIS mode only – prefer QGIS Auth Manager instead) ───────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=energy
POSTGRES_USER=readonly
POSTGRES_PASSWORD=

# ── Geocoding ─────────────────────────────────────────────────────────────────
NOMINATIM_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=solar-sites/1.0
NOMINATIM_DELAY_S=1.1

# ── YOLO detection (optional, requires leafmap + ultralytics) ─────────────────
DETECTION_CONFIDENCE=0.80
SATELLITE_ZOOM=19
